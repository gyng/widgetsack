{
	"name": "client",
	"version": "0.0.1",
	"license": "MIT OR Apache-2.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "tsc --noEmit",
		"test:unit": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"lint": "oxfmt --check . && oxlint . --max-warnings=0",
		"lint:fix": "oxfmt --write . && oxlint . --max-warnings=0 --fix",
		"format": "oxfmt --write .",
		"mcp": "vite-node mcp/server.ts",
		"gen:docs": "vite-node scripts/gen-widget-docs.ts",
		"check:docs": "vite-node scripts/gen-widget-docs.ts --check",
		"gen:shots": "node scripts/screenshots.mjs",
		"gen:gallery": "npm run gen:shots && npm run gen:docs"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@testing-library/dom": "^10.4.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@testing-library/user-event": "^14.5.2",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.9",
		"happy-dom": "^20.10.6",
		"oxfmt": "^0.58.0",
		"oxlint": "^1.73.0",
		"tslib": "^2.8.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.3",
		"vite-node": "^6.0.0",
		"vitest": "^4.1.9"
	},
	"type": "module",
	"dependencies": {
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/language": "^6.12.3",
		"@codemirror/lint": "^6.9.6",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.0",
		"@jitl/quickjs-singlefile-browser-release-sync": "^0.32.0",
		"@lezer/common": "^1.5.2",
		"@lezer/highlight": "^1.2.3",
		"@tauri-apps/api": "^2.11.0",
		"downshift": "^9.3.6",
		"quickjs-emscripten-core": "^0.32.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	}
}
