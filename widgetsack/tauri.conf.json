{
  "build": {
    "beforeBuildCommand": "cd ../client && npm run build",
    "beforeDevCommand": "cd ../client && npm run dev",
    "frontendDist": "../client/build",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "copyright": "Copyright © 2023-2026 Ng Guoyou. MIT OR Apache-2.0.",
    "targets": ["nsis"],
    "externalBin": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerHooks": "./windows/hooks.nsh",
        "installerIcon": "./icons/icon.ico",
        "headerImage": "./windows/installer-header.bmp",
        "sidebarImage": "./windows/installer-sidebar.bmp"
      }
    },
    "longDescription": "WidgetSack desktop widget platform",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "shortDescription": "",
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "createUpdaterArtifacts": false
  },
  "productName": "widgetsack",
  "version": "0.0.36",
  "identifier": "io.github.gyng",
  "plugins": {},
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "fullscreen": false,
        "height": 400,
        "resizable": true,
        "title": "WidgetSack",
        "width": 300,
        "transparent": true,
        "shadow": false,
        "decorations": false,
        "alwaysOnTop": false,
        "alwaysOnBottom": true,
        "skipTaskbar": true,
        "visible": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "scope": {
          "allow": [
            "C:/Windows/Fonts/**",
            "$LOCALDATA/Microsoft/Windows/Fonts/**",
            "$APPCONFIG/**"
          ],
          "requireLiteralLeadingDot": true
        },
        "enable": true
      },
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob: data:; font-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost; script-src 'self' 'wasm-unsafe-eval'; frame-src 'self' http: https:"
    }
  }
}